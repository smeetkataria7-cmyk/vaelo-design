# ── Vaelo Agency OS — environment ───────────────────────────────────────────
# Copy to .env.local and fill in. Secrets are SERVER-ONLY: never prefix a secret
# with NEXT_PUBLIC_. Only the URL + anon key are safe to expose to the browser.

# Supabase (project: iqtkgkwgyxfbyetxyjqp)
NEXT_PUBLIC_SUPABASE_URL="https://iqtkgkwgyxfbyetxyjqp.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""          # Project Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=""              # Project Settings → API → service_role (SECRET)

# ── Access / roles ──────────────────────────────────────────────────────────
# Comma-separated emails. Master admins are admins too. These bootstrap roles
# without a DB; the team_members table (role = 'admin' | 'super') can add more.
# Anyone who signs in and is in NEITHER list is treated as a CLIENT (portal).
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=""         # e.g. owner@vaelocreative.com  → master admin
NEXT_PUBLIC_ADMIN_EMAILS=""               # e.g. staff1@vaelo.co, staff2@vaelo.co → admins

# Prisma / Postgres (Project Settings → Database → Connection string)
# Pooled (PgBouncer, port 6543) for the app; direct (5432) for migrations.
DATABASE_URL="postgresql://postgres.iqtkgkwgyxfbyetxyjqp:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.iqtkgkwgyxfbyetxyjqp:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Toggle the data source: "mock" (default) or "supabase"
NEXT_PUBLIC_DATA_SOURCE="mock"

# Integrations (added per roadmap phase) ─────────────────────────────────────
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""
# RESEND_API_KEY=""
# ANTHROPIC_API_KEY=""
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# META_APP_ID=""
# META_APP_SECRET=""
# FAL_KEY=""

# Public site URL (safe to expose)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
